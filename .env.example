# MongoDB Connection String
# For local: mongodb://127.0.0.1:27017/bookAndBite
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/bookAndBite
MONGODB_URI=

# JWT Secret for authentication
JWT_SECRET=

# Email Configuration (Nodemailer)
EMAIL=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Admin Credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Node Environment
NODE_ENV=development
